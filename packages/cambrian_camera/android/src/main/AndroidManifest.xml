<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Camera permission and features are declared here so the plugin's
         requirements are visible to the app's merged manifest. The app
         must also request CAMERA permission at runtime on API 23+. -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-feature
        android:name="android.hardware.camera"
        android:required="false" />
    <uses-feature
        android:name="android.hardware.camera.autofocus"
        android:required="false" />
    <application>
        <!-- Debug/dev only: exported=true for ADB broadcasts, no permission guard. Remove or restrict for production. -->
        <receiver
            android:name="com.cambrian.camera.VideoRecordingReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="com.cambrian.camera.START_RECORDING" />
                <action android:name="com.cambrian.camera.STOP_RECORDING" />
            </intent-filter>
        </receiver>
    </application>
</manifest>
