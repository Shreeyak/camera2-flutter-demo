<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Camera permission and features are declared here so the plugin's
         requirements are visible to the app's merged manifest. The app
         must also request CAMERA permission at runtime on API 23+. -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-feature
        android:name="android.hardware.camera"
        android:required="false" />
    <uses-feature
        android:name="android.hardware.camera.autofocus"
        android:required="false" />

    <application>
        <receiver
            android:name=".LogLevelReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="com.cambrian.camera.SET_LOG_LEVEL" />
            </intent-filter>
        </receiver>
    </application>
</manifest>
